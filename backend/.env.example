# --- Connexion Oracle Prod SNDE ---
ORACLE_USER=DCAA
ORACLE_PASSWORD=changeme
ORACLE_HOST=192.168.10.30
ORACLE_PORT=1521
ORACLE_SERVICE_NAME=Sigasnde
ORACLE_SCHEMA=CRM_SNDE

# --- Pool ---
ORACLE_POOL_MIN=2
ORACLE_POOL_MAX=5
ORACLE_POOL_INCREMENT=1

# --- App ---
APP_HOST=0.0.0.0
APP_PORT=8001
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
LOG_LEVEL=INFO

# --- DuckDB cache ---
DUCKDB_PATH=data/snde.duckdb

# Tous les centres Nouakchott (laisser vide). Pour limiter : "97" ou "97,98"
CENTRES_INCLUS=

# Périmètre métier
ZONE_ID=2
EGF_MONTHS_ROLLING=2

# Scheduler (refresh incrémental périodique du mois courant uniquement)
REFRESH_INTERVAL_MINUTES=15
